        <mxCell id="ml_train_lbl" value="SageMaker Training&lt;br&gt;XGBoost 학습" vertex="1" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontFamily=Verdana;fontSize=16;fontColor=#1F2933;align=center;verticalAlign=top;whiteSpace=wrap;"><mxGeometry x="1134" y="2060" width="210" height="60" as="geometry" /></mxCell>
        <mxCell id="ml_m1" value="M1 출근확률&lt;br&gt;이진분류·XGBoost&lt;br&gt;출력 P(출근)" vertex="1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E9F8F5;strokeColor=#00695C;fontFamily=Verdana;fontSize=15;fontColor=#1F2933;align=center;verticalAlign=middle;spacing=6;strokeWidth=2;"><mxGeometry x="1140" y="2220" width="210" height="110" as="geometry" /></mxCell>
        <mxCell id="ml_m3" value="M3 수락확률·랭킹&lt;br&gt;XGBoost / LogReg" vertex="1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E9F8F5;strokeColor=#00695C;fontFamily=Verdana;fontSize=15;fontColor=#1F2933;align=center;verticalAlign=middle;spacing=6;strokeWidth=2;"><mxGeometry x="1380" y="2220" width="210" height="110" as="geometry" /></mxCell>
        <mxCell id="ml_reg" value="" vertex="1" parent="1" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;html=1;fontSize=12;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.sagemaker;fillColor=#01A88D;strokeColor=#ffffff;fontFamily=Verdana;strokeWidth=2;"><mxGeometry x="1700" y="1980" width="78" height="78" as="geometry" /></mxCell>
        <mxCell id="ml_reg_lbl" value="Model Registry&lt;br&gt;버전·승인 관리" vertex="1" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontFamily=Verdana;fontSize=16;fontColor=#1F2933;align=center;verticalAlign=top;whiteSpace=wrap;"><mxGeometry x="1634" y="2060" width="210" height="60" as="geometry" /></mxCell>
        <mxCell id="ml_eb" value="" vertex="1" parent="1" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;html=1;fontSize=12;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.eventbridge;fillColor=#E7157B;strokeColor=#ffffff;fontFamily=Verdana;strokeWidth=2;"><mxGeometry x="2040" y="1980" width="78" height="78" as="geometry" /></mxCell>
        <mxCell id="ml_eb_lbl" value="EventBridge&lt;br&gt;야간 배치 스케줄" vertex="1" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontFamily=Verdana;fontSize=16;fontColor=#1F2933;align=center;verticalAlign=top;whiteSpace=wrap;"><mxGeometry x="1974" y="2060" width="210" height="60" as="geometry" /></mxCell>
        <mxCell id="ml_sfn" value="" vertex="1" parent="1" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;html=1;fontSize=12;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.step_functions;fillColor=#ED7100;strokeColor=#ffffff;fontFamily=Verdana;strokeWidth=2;"><mxGeometry x="2340" y="1980" width="78" height="78" as="geometry" /></mxCell>
        <mxCell id="ml_sfn_lbl" value="Step Functions&lt;br&gt;재학습 파이프라인" vertex="1" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontFamily=Verdana;fontSize=16;fontColor=#1F2933;align=center;verticalAlign=top;whiteSpace=wrap;"><mxGeometry x="2274" y="2060" width="210" height="60" as="geometry" /></mxCell>
        <mxCell id="ml_nM1" value="M1 피처 (출근확률)&lt;br&gt;• 최근 30일 출근율 / 연속 스트릭&lt;br&gt;• 자택–현장 거리 / 요일&lt;br&gt;• 배정 통보 리드타임 / 일당&lt;br&gt;• 공정 경험 횟수 / 기상(mock)&lt;br&gt;&lt;br&gt;→ 작업조 안정성 = ∏ P(출근)&lt;br&gt;   개인값 비공개(내부 변수)" vertex="1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E9F8F5;strokeColor=#01A88D;fontFamily=Verdana;fontSize=14;fontColor=#00695C;align=left;verticalAlign=top;spacing=10;dashed=1;strokeWidth=1;"><mxGeometry x="2760" y="1860" width="380" height="300" as="geometry" /></mxCell>
        <mxCell id="ml_nM3" value="M3 피처 (수락확률)&lt;br&gt;• 후보–현장 거리 / 시간대&lt;br&gt;• 제시 보너스 금액&lt;br&gt;• 과거 수락률 / 당일 가용성&lt;br&gt;• ETA(도착 가능성)&lt;br&gt;&lt;br&gt;→ 기대 충원 성공률 =&lt;br&gt;   P(수락) × 도착 가능성" vertex="1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E9F8F5;strokeColor=#01A88D;fontFamily=Verdana;fontSize=14;fontColor=#00695C;align=left;verticalAlign=top;spacing=10;dashed=1;strokeWidth=1;"><mxGeometry x="3160" y="1860" width="380" height="300" as="geometry" /></mxCell>
        <mxCell id="ml_nM2" value="M2 편성 최적화 (Lambda·비학습)&lt;br&gt;&lt;br&gt;Score = w₁·숙련 + w₂·비용&lt;br&gt;  + w₃·근접 + w₄·안정성(M1)&lt;br&gt;(Σw=1, 관리자 슬라이더 가중치)&lt;br&gt;&lt;br&gt;제약: 직종별 필수 인원·자격&lt;br&gt;후보 필터 → Greedy → Local Search&lt;br&gt;확장: OR-Tools CP-SAT" vertex="1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E9;strokeColor=#ED7100;fontFamily=Verdana;fontSize=14;fontColor=#8A3B00;align=left;verticalAlign=top;spacing=10;dashed=1;strokeWidth=1;"><mxGeometry x="2760" y="2200" width="380" height="300" as="geometry" /></mxCell>
        <mxCell id="ml_nM4" value="M4 생성형 AI (Bedrock·프롬프트)&lt;br&gt;학습 불필요&lt;br&gt;&lt;br&gt;① 자연어 → JSON 매칭 조건 파싱&lt;br&gt;② 피처 중요도 → 매칭 사유(XAI)&lt;br&gt;③ 일일 운영 리포트 생성&lt;br&gt;Knowledge Base(RAG) 연계" vertex="1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E9F8F5;strokeColor=#01A88D;fontFamily=Verdana;fontSize=14;fontColor=#00695C;align=left;verticalAlign=top;spacing=10;dashed=1;strokeWidth=1;"><mxGeometry x="3160" y="2200" width="380" height="300" as="geometry" /></mxCell>
        <mxCell id="ml_retrain" value="MLOps 루프: 신규 확정 출결·배차 응답 축적 → S3 → 재학습 → 검증 지표(AUC/F1) 통과 시 Registry 승인 → Endpoint 무중단 배포. 폴백: 로컬 학습 아티팩트를 Lambda 컨테이너 추론으로 대체." vertex="1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEF0FB;strokeColor=#3B48CC;fontFamily=Verdana;fontSize=14;fontColor=#26308F;align=left;verticalAlign=top;spacing=10;dashed=1;strokeWidth=1;"><mxGeometry x="2640" y="2520" width="900" height="90" as="geometry" /></mxCell>
