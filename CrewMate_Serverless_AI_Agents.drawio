        <mxCell id="i_sm" value="" vertex="1" parent="1" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;html=1;fontSize=12;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.sagemaker;fillColor=#01A88D;strokeColor=#ffffff;fontFamily=Verdana;strokeWidth=2;"><mxGeometry x="2800" y="1160" width="78" height="78" as="geometry" /></mxCell>
        <mxCell id="i_sm_lbl" value="SageMaker Endpoint&lt;br&gt;M1·M3 서버리스 추론" vertex="1" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontFamily=Verdana;fontSize=16;fontColor=#1F2933;align=center;verticalAlign=top;whiteSpace=wrap;"><mxGeometry x="2734" y="1240" width="210" height="60" as="geometry" /></mxCell>
        <mxCell id="n_agentA" value="에이전트 A 추론 루프&lt;br&gt;&lt;br&gt;1) 관리자 요청(폼·자연어) 해석 → 직종·인원·기간·가중치(비용/숙련/근접/안정성) 구조화&lt;br&gt;2) 후보 풀 조회 → 제약(직종별 필수 인원·자격) 필터링&lt;br&gt;3) M1 출근확률 + 숙련·비용·근접 결합해 안정성 점수 계산&lt;br&gt;4) M2 최적화로 상위 3개 조합 도출&lt;br&gt;5) Bedrock으로 매칭 사유(XAI) 생성 후 관리자에게 반환" vertex="1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7E6;strokeColor=#F0A030;fontFamily=Verdana;fontSize=14;fontColor=#7A4C00;align=left;verticalAlign=top;spacing=10;dashed=1;strokeWidth=1;"><mxGeometry x="3320" y="400" width="700" height="300" as="geometry" /></mxCell>
        <mxCell id="n_agentB" value="에이전트 B 판단 로직&lt;br&gt;&lt;br&gt;결원 컨텍스트 수집: 배차 상태(DynamoDB) · 위치·ETA(Location) · 출근 가능성·경력·수락 이력&lt;br&gt;&lt;br&gt;→ M3 수락확률 예측 결합&lt;br&gt;→ 기대 충원 성공률 = 수락확률 × 도착 가능성&lt;br&gt;→ 최적 대체 순위 판단 → 상위 후보부터 순차 배차(SQS→SNS)&lt;br&gt;→ 수락 시 작업조 갱신·WebSocket 실시간 반영" vertex="1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7E6;strokeColor=#F0A030;fontFamily=Verdana;fontSize=14;fontColor=#7A4C00;align=left;verticalAlign=top;spacing=10;dashed=1;strokeWidth=1;"><mxGeometry x="3320" y="760" width="700" height="340" as="geometry" /></mxCell>
        <mxCell id="ml_faker" value="Faker 합성 데이터 (시드 고정)&lt;br&gt;근로자 800·현장 20&lt;br&gt;출결 90일·배차응답 500" vertex="1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#26308F;fontFamily=Verdana;fontSize=15;fontColor=#1F2933;align=center;verticalAlign=middle;spacing=6;strokeWidth=2;"><mxGeometry x="120" y="1900" width="320" height="140" as="geometry" /></mxCell>
        <mxCell id="ml_hist" value="Aurora 확정 이력 export&lt;br&gt;(지오펜스 출결+승인 = 라벨)" vertex="1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#26308F;fontFamily=Verdana;fontSize=15;fontColor=#1F2933;align=center;verticalAlign=middle;spacing=6;strokeWidth=2;"><mxGeometry x="120" y="2120" width="320" height="110" as="geometry" /></mxCell>
        <mxCell id="ml_s3" value="" vertex="1" parent="1" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;html=1;fontSize=12;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.s3;fillColor=#7AA116;strokeColor=#ffffff;fontFamily=Verdana;strokeWidth=2;"><mxGeometry x="560" y="1980" width="78" height="78" as="geometry" /></mxCell>
